{
  "manifest_version": 3,
  "name": "MetVUW Plus",
  "version": "1.0.0",
  "minimum_chrome_version": "88",
  "description": "Enhances metvuw.co.nz with a lightbox viewer, animated slideshow, scrub bar, keyboard navigation, and saved preferences — for forecast, satellite, and radar pages.",
  "permissions": ["storage"],
  "host_permissions": ["*://metvuw.co.nz/*"],
  "content_scripts": [
    {
      "matches": [
        "*://metvuw.co.nz/forecast/forecast.php*",
        "*://metvuw.co.nz/satellite/*",
        "*://metvuw.co.nz/radar/radar.php*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://metvuw.co.nz/forecast/", "*://metvuw.co.nz/forecast"],
      "js": ["content/redirect.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
